{
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Đăng ký tài khoản",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/RegisterSuccess"
          },
          "403": {
            "$ref": "#/components/responses/ForbiddenError"
          }
        }
      }
    },
    "/api/auth/verify-email": {
      "post": {
        "summary": "Xác thực email",
        "description": "Xác thực tài khoản bằng token gửi qua email (refreshToken được set qua cookie)",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "$ref": "#/components/responses/VerifyEmailSuccess"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },

    "/api/auth/logout": {
      "post": {
        "summary": "Logout",
        "tags": ["Auth"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/LogoutSuccess"
          }
        }
      }
    },

    "/api/auth/refresh": {
      "post": {
        "summary": "Làm mới access token",
        "tags": ["Auth"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": false,
          "content": {}
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/RefreshSuccess"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/auth/google": {
      "post": {
        "summary": "Đăng nhập bằng Google",
        "description": "Xác thực người dùng bằng Google idToken",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleLoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/GoogleLoginSuccess"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "summary": "Quên mật khẩu",
        "description": "Gửi email chứa link reset mật khẩu",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ForgotPasswordSuccess"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "summary": "Đặt lại mật khẩu",
        "description": "Đặt lại mật khẩu bằng token gửi qua email",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ResetPasswordSuccess"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/api/auth/set-password": {
      "post": {
        "summary": "Đặt lại mật khẩu",
        "description": "Đặt lại mật khẩu bằng token reset và trả về accessToken + refreshToken",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SetPasswordSuccess"
          }
        }
      }
    },
    "/api/auth/set-password/me": {
      "post": {
        "summary": "Đặt lại mật khẩu của tôi",
        "description": "Đặt lại mật khẩu của người dùng hiện tại (yêu cầu xác thực)",
        "tags": ["Auth"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetPasswordMeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SetPasswordSuccess"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    }
  },

  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "GoogleLoginRequest": {
        "type": "object",
        "required": ["idToken"],
        "properties": {
          "idToken": {
            "type": "string",
            "example": "eyJhbGciOiJSUzI1NiIsImtpZCI6..."
          }
        }
      },

      "RegisterRequest": {
        "type": "object",
        "required": [
          "email",
          "password",
          "confirmPassword",
          "fullName",
          "targetScore",
          "wordsPerDay"
        ],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" },
          "confirmPassword": { "type": "string" },
          "fullName": { "type": "string" },
          "targetScore": { "type": "integer" },
          "wordsPerDay": { "type": "integer" }
        }
      },

      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "displayName": { "type": "string" },
          "targetScore": { "type": "integer" },
          "streak": { "type": "integer" },
          "avatarUrl": { "type": "string", "nullable": true },
          "wordsPerDay": { "type": "integer" }
        }
      },

      "LoginResponse": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "expiresIn": { "type": "number" },
          "rawRefreshToken": { "type": "string" },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "RefreshResponseData": {
        "type": "object",
        "properties": {
          "accessToken": { "type": "string" },
          "refreshToken": { "type": "string" },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },

      "ResetPasswordRequest": {
        "type": "object",
        "required": ["token", "password", "confirmPassword"],
        "properties": {
          "token": {
            "type": "string",
            "example": "abc123resetToken"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "Abc123@"
          },
          "confirmPassword": {
            "type": "string",
            "example": "Abc123@"
          }
        }
      },

      "ForgotPasswordRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "test@gmail.com"
          }
        }
      },

      "BaseSuccess": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": { "type": "object" }
        }
      },

      "BaseError": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" }
        }
      },
      "SetPasswordRequest": {
        "type": "object",
        "required": ["token", "newPassword", "confirmPassword"],
        "properties": {
          "token": {
            "type": "string",
            "example": "reset-token-abc123"
          },
          "newPassword": {
            "type": "string",
            "minLength": 8,
            "example": "Abc123@",
            "description": "Mật khẩu mới (phải chứa chữ hoa, chữ thường, số và ký tự đặc biệt)"
          },
          "confirmPassword": {
            "type": "string",
            "minLength": 8,
            "example": "Abc123@",
            "description": "Xác nhận mật khẩu"
          }
        }
      },
      "SetPasswordMeRequest": {
        "type": "object",
        "required": ["newPassword", "confirmPassword"],
        "properties": {
          "newPassword": {
            "type": "string",
            "minLength": 8,
            "example": "Abc123@",
            "description": "Mật khẩu mới (phải chứa chữ hoa, chữ thường, số và ký tự đặc biệt)"
          },
          "confirmPassword": {
            "type": "string",
            "minLength": 8,
            "example": "Abc123@",
            "description": "Xác nhận mật khẩu"
          }
        }
      }
    },

    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BaseError"
            }
          }
        }
      },

      "ForbiddenError": {
        "description": "Email đã tồn tại",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BaseError"
            }
          }
        }
      },

      "UnauthorizedError": {
        "description": "Token không hợp lệ",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BaseError"
            }
          }
        }
      },

      "RegisterSuccess": {
        "description": "Đăng ký thành công",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/BaseSuccess"
                },
                {
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": { "type": "string" }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },

      "LogoutSuccess": {
        "description": "Logout thành công",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BaseSuccess"
            }
          }
        }
      },

      "RefreshSuccess": {
        "description": "Refresh token thành công",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/BaseSuccess"
                },
                {
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/RefreshResponseData"
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "GoogleLoginSuccess": {
        "description": "Đăng nhập Google thành công",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/BaseSuccess"
                },
                {
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "accessToken": {
                          "type": "string",
                          "example": "access-token"
                        },
                        "user": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "ResetPasswordSuccess": {
        "description": "Đặt lại mật khẩu thành công",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BaseSuccess"
            },
            "example": {
              "success": true,
              "data": {
                "message": "Đặt lại mật khẩu thành công"
              }
            }
          }
        }
      },
      "ForgotPasswordSuccess": {
        "description": "Gửi email thành công",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BaseSuccess"
            },
            "example": {
              "success": true,
              "data": {
                "message": "Vui lòng kiểm tra email để đặt lại mật khẩu"
              }
            }
          }
        }
      },
      "VerifyEmailSuccess": {
        "description": "Xác thực email thành công",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/BaseSuccess"
                },
                {
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "accessToken": {
                          "type": "string",
                          "example": "access-token"
                        },
                        "user": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "SetPasswordSuccess": {
        "description": "Đặt lại mật khẩu thành công",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/BaseSuccess"
                },
                {
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "message": {
                          "type": "string",
                          "example": "Đặt lại mật khẩu thành công"
                        },
                        "accessToken": {
                          "type": "string",
                          "example": "access-token"
                        },
                        "refreshToken": {
                          "type": "string",
                          "example": "refresh-token"
                        },
                        "user": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
